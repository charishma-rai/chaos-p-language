<!DOCTYPE html>
<html>
    <head>

    <title>P Language Translator</title>

    <style>

            body{
                font-family:Arial;
                background:linear-gradient(135deg,#ffd6f5,#d0f0ff);
                display:flex;
                flex-direction:column;
                align-items:center;
                justify-content:center;
                height:100vh;
                margin:0;
                text-align:center;
                overflow:hidden;
            }

            h1{
                font-size:40px;
                margin-bottom:5px;
            }

            #subtitle{
                opacity:0.8;
                margin-bottom:20px;
            }

            textarea{
                width:420px;
                height:120px;
                padding:12px;
                font-size:16px;
                border-radius:15px;
                border:none;
                margin-top:15px;
                box-shadow:0 4px 10px rgba(0,0,0,0.1);
            }

            button{
                margin-top:10px;
                padding:10px 20px;
                font-size:16px;
                border:none;
                border-radius:20px;
                background:#6a5acd;
                color:white;
                cursor:pointer;
                box-shadow:0 4px 10px rgba(0,0,0,0.2);
            }

            button:hover{
                background:#7b6cff;
            }

            #output{
                margin-top:30px;
                font-size:22px;
                font-weight:bold;
                max-width:600px;
                word-wrap:break-word;
                background:white;
                padding:15px;
                border-radius:15px;
                box-shadow:0 6px 15px rgba(0,0,0,0.15);
            }

            #message{
                margin-top:15px;
                font-size:18px;
                color:#444;
            }

            #hint{
                margin-top:10px;
                font-size:16px;
                opacity:0.7;
                font-style:italic;
            }

            .float{
                position:absolute;
                font-size:28px;
                animation:float 6s infinite linear;
                opacity:0.6;
            }

            @keyframes float{
                0%{transform:translateY(100vh);}
                100%{transform:translateY(-100px);}
            }

    </style>
    </head>

    <body>

            <h1>P Language Translator 🗣️</h1>
            <div id="subtitle">Turn normal words into secret chaos</div>
            <textarea id="inputText" placeholder="Type something..." oninput="convert()"></textarea>

            <br>

            <button onclick="copyText()">Copy Result</button>
            <button onclick="chaosMode()">Chaos Mode</button>
            <button onclick="normalMode()">Normal Mode</button>

            <div id="output">Your secret language will appear here...</div>

            <div id="message">✨ The language spirits are waiting.</div>
            <div id="hint">🧩 Can you figure out the rule?</div>

            <script>

                let chaos=false;

                let funMessages=[
                "✨ Secret code activated.",
                "🧠 Brain upgrade complete.",
                "🕵️ Spy language detected.",
                "📜 Ancient nonsense unlocked.",
                "🎭 Linguistic chaos achieved."
                ];

                let hints=[
                "🔍 Notice what happens to vowels...",
                "🧠 Something repeats after certain letters.",
                "👀 Look closely at A, E, I, O, U.",
                "🕵️ The pattern hides in plain sight.",
                "📜 The secret lives inside the sounds."
                ];

                function translate(text){

                let vowels="aeiouAEIOU";
                let result="";

                for(let i=0;i<text.length;i++){

                let letter=text[i];

                result+=letter;

                if(vowels.includes(letter)){
                result+="p"+letter;
                }

                }

                return result;

                }

                function convert(){

                let text=document.getElementById("inputText").value;

                let translated=translate(text);

                if(chaos){
                translated=translate(translated);
                }

                document.getElementById("output").innerText=translated;

                document.getElementById("message").innerText=
                funMessages[Math.floor(Math.random()*funMessages.length)];

                document.getElementById("hint").innerText=
                hints[Math.floor(Math.random()*hints.length)];

                }

                function copyText(){

                let text=document.getElementById("output").innerText;

                navigator.clipboard.writeText(text);

                document.getElementById("message").innerText=
                "📋 Copied! Now confuse your friends.";

                }

                function chaosMode(){

                chaos=true;

                convert();

                document.getElementById("message").innerText=
                "🌪 Chaos Mode Activated.";

                }

                function normalMode(){

                chaos=false;

                convert();

                document.getElementById("message").innerText=
                "✨ Normal Mode Restored.";

                }

                function createFloating(){s

                let emojis=["✨","🫧","🌈","💬","🧁"];

                let e=document.createElement("div");

                e.className="float";

                e.innerText=emojis[Math.floor(Math.random()*emojis.length)];

                e.style.left=Math.random()*window.innerWidth+"px";

                document.body.appendChild(e);

                setTimeout(()=>{
                e.remove();
                },6000);

                }

                setInterval(createFloating,900);

            </script>

    </body>
</html>